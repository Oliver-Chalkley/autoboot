# Debian Preseed Configuration
# Generated by autoboot for {{ config.machine_name }}

# Locale and keyboard
d-i debian-installer/locale string {{ config.locale }}
d-i keyboard-configuration/xkb-keymap select {{ config.keyboard_layout }}

# Network
d-i netcfg/choose_interface select auto
{% if config.network.type == "dhcp" %}
d-i netcfg/disable_autoconfig boolean false
{% else %}
d-i netcfg/disable_autoconfig boolean true
d-i netcfg/get_ipaddress string {{ config.network.address.split('/')[0] }}
d-i netcfg/get_netmask string 255.255.255.0
d-i netcfg/get_gateway string {{ config.network.gateway }}
{% if config.network.dns %}
d-i netcfg/get_nameservers string {{ config.network.dns[0] }}
{% endif %}
d-i netcfg/confirm_static boolean true
{% endif %}
d-i netcfg/get_hostname string {{ config.hostname }}
d-i netcfg/get_domain string local

# Mirror
d-i mirror/country string manual
d-i mirror/http/hostname string deb.debian.org
d-i mirror/http/directory string /debian
d-i mirror/http/proxy string

# Clock and timezone
d-i clock-setup/utc boolean true
d-i time/zone string {{ config.timezone }}

# Partitioning
d-i partman-auto/method string {{ config.storage.layout }}
d-i partman-lvm/device_remove_lvm boolean true
d-i partman-md/device_remove_md boolean true
d-i partman-lvm/confirm boolean true
d-i partman-lvm/confirm_nooverwrite boolean true
d-i partman-auto/choose_recipe select atomic
d-i partman-partitioning/confirm_write_new_label boolean true
d-i partman/choose_partition select finish
d-i partman/confirm boolean true
d-i partman/confirm_nooverwrite boolean true

# User account
d-i passwd/user-fullname string {{ config.admin.real_name }}
d-i passwd/username string {{ config.admin.username }}
d-i passwd/user-password-crypted password {{ config.admin.password_hash }}
d-i user-setup/allow-password-weak boolean true

# Package selection
tasksel tasksel/first multiselect standard, ssh-server
d-i pkgsel/include string python3 openssh-server sudo{% for pkg in config.packages %} {{ pkg }}{% endfor %}

d-i pkgsel/upgrade select full-upgrade
popularity-contest popularity-contest/participate boolean false

# GRUB
d-i grub-installer/only_debian boolean true
d-i grub-installer/bootdev string default

# Late commands - create ansible user with SSH key
d-i preseed/late_command string \
    in-target useradd -m -s /bin/bash -G sudo ansible; \
    in-target mkdir -p /home/ansible/.ssh; \
    echo '{{ ssh_key }}' > /target/home/ansible/.ssh/authorized_keys; \
    in-target chown -R ansible:ansible /home/ansible/.ssh; \
    in-target chmod 700 /home/ansible/.ssh; \
    in-target chmod 600 /home/ansible/.ssh/authorized_keys; \
    echo 'ansible ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/ansible; \
    in-target chmod 440 /etc/sudoers.d/ansible; \
    touch /target/var/log/autoinstall-success{% for cmd in config.extra_late_commands %}; \
    {{ cmd }}{% endfor %}

# Finish
d-i finish-install/reboot_in_progress note
