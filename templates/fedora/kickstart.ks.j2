# Fedora Kickstart Configuration
# Generated by autoboot for {{ config.machine_name }}

# System language and keyboard
lang {{ config.locale }}
keyboard --xlayouts='{{ config.keyboard_layout }}'

# Timezone
timezone {{ config.timezone }} --utc

# Network
{% if config.network.type == "dhcp" %}
network --bootproto=dhcp --hostname={{ config.hostname }} --activate
{% else %}
network --bootproto=static --ip={{ config.network.address.split('/')[0] }} --netmask=255.255.255.0 --gateway={{ config.network.gateway }}{% if config.network.dns %} --nameserver={{ config.network.dns | join(',') }}{% endif %} --hostname={{ config.hostname }} --activate
{% endif %}

# Root password (locked - no root login)
rootpw --lock

# Admin user
user --name={{ config.admin.username }} --password={{ config.admin.password_hash }} --iscrypted --gecos="{{ config.admin.real_name }}"

# Partitioning
clearpart --all --initlabel
{% if config.storage.layout == "lvm" %}
autopart --type=lvm
{% else %}
autopart --type=plain
{% endif %}

# Bootloader
bootloader --append="crashkernel=auto"

# Firewall and services
firewall --enabled --ssh
services --enabled=sshd

# SELinux
selinux --enforcing

# Reboot after install
reboot

# Packages
%packages
@^server-product-environment
python3
openssh-server
sudo
{% for pkg in config.packages %}
{{ pkg }}
{% endfor %}
%end

# Post-install: create ansible user with SSH key and passwordless sudo
%post --log=/root/ks-post.log
useradd -m -s /bin/bash -G wheel ansible
mkdir -p /home/ansible/.ssh
echo '{{ ssh_key }}' > /home/ansible/.ssh/authorized_keys
chown -R ansible:ansible /home/ansible/.ssh
chmod 700 /home/ansible/.ssh
chmod 600 /home/ansible/.ssh/authorized_keys

echo 'ansible ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/ansible
chmod 440 /etc/sudoers.d/ansible

touch /var/log/autoinstall-success
{% for cmd in config.extra_late_commands %}
{{ cmd }}
{% endfor %}
%end
